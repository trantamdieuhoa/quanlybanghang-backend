# ── Database ─────────────────────────────────────
# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/quanlybanghang

# ── Auth ──────────────────────────────────────────
JWT_SECRET=your_super_secret_key_here_min_32_chars
JWT_EXPIRES_IN=1h
# Secret riêng cho refresh token — PHẢI khác JWT_SECRET, chuỗi ngẫu nhiên >= 32 ký tự
JWT_REFRESH_SECRET=your_other_super_secret_key_here_min_32_chars
JWT_REFRESH_EXPIRES_IN=7d

# ── Server ────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Security ─────────────────────────────────────
# Bỏ trống để cho phép mọi IP (Railway/cloud)
# ALLOWED_SUBNET=192.168.1

# ── Google Sheets (tuỳ chọn) ─────────────────────
# GOOGLE_SHEET_ID=
# GOOGLE_SERVICE_ACCOUNT_EMAIL=
# GOOGLE_PRIVATE_KEY=

# ── Backup (tuỳ chọn, scripts/backup_mongo.js) ───
# Thư mục lưu backup .gz trên PC. Mặc định: <repo>/../../backups
# BACKUP_DIR=D:\botreply\quanlybanghang\backups
# Số bản backup gần nhất giữ lại (mặc định 14)
# BACKUP_KEEP=14
